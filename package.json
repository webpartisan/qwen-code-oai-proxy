{
  "name": "qwen-openai-proxy",
  "version": "1.0.0",
  "description": "A proxy server that exposes Qwen models through an OpenAI-compatible API",
  "main": "src/index.js",
  "scripts": {
    "start": "node --env-file=.env src/index.js",
    "dev": "node src/index.js",
    "test": "jest",
    "test:simple": "node test-simple.js",
    "test:all": "node test-all-accounts.js",
    "auth": "node authenticate.js",
    "auth:list": "node authenticate.js list",
    "auth:add": "node authenticate.js add",
    "auth:remove": "node authenticate.js remove",
    "auth:counts": "node authenticate.js counts",
    "auth:tokens": "node usage.js",
    "tokens": "node usage.js",
    "usage": "node usage.js",
    "health": "node health.js"
  },
  "keywords": [
    "qwen",
    "openai",
    "proxy",
    "api"
  ],
  "author": "Qwen Code Developer",
  "license": "Apache-2.0",
  "dependencies": {
    "axios": "^1.11.0",
    "cli-table3": "^0.6.5",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "open": "^8.4.0",
    "openai": "^4.20.0",
    "proxy-agent": "^6.5.0",
    "qrcode-terminal": "^0.12.0",
    "tiktoken": "^1.0.22",
    "undici": "^7.13.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.1"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.js",
      "**/*.test.js"
    ],
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/index.js"
    ],
    "coverageDirectory": "coverage",
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "/test/"
    ]
  }
}
